{
  "manifest_version": 3,
  "name": "Dwarfer GIF",
  "version": "0.5.4",
  "description": "Experimental: pick and view GIFs inline in YouTube comments via dwarfer.link. Not affiliated with YouTube or Google.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://dwarfer.link/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/youtube.js"],
      "css": ["content/youtube.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
